.container {
  padding: 32rpx;
  padding-bottom: 160rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 8rpx solid #e5e7eb;
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 32rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 30rpx;
  color: var(--color-text);
  font-weight: 500;
  margin-bottom: 12rpx;
}

.loading-time {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* 对比区域 */
.comparer-wrapper {
  margin-top: 24rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
}

/* 操作按钮 */
.actions {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}

.btn-save,
.btn-share {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  font-weight: 500;
  padding: 24rpx 0;
}

.btn-save {
  background: #f3f4f6;
  color: var(--color-text);
}

.btn-share {
  background: var(--color-primary);
  color: var(--color-white);
  box-shadow: 0 8rpx 24rpx rgba(34, 197, 94, 0.3);
}

/* 反馈 */
.feedback {
  margin-top: 48rpx;
  text-align: center;
}

.feedback-title {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: 24rpx;
}

.feedback-options {
  display: flex;
  justify-content: center;
  gap: 60rpx;
}

.feedback-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 40rpx;
  border-radius: var(--radius-md);
  background: var(--color-white);
  border: 2rpx solid var(--color-border);
}

.feedback-item.selected {
  border-color: var(--color-primary);
  background: #f0fdf4;
}

.feedback-emoji {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.feedback-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* 继续处理 */
.continue {
  margin-top: 48rpx;
  text-align: center;
}

.continue-link {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 500;
}
