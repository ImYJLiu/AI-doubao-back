.container {
  padding: 32rpx;
  padding-bottom: 160rpx;
}

/* 头部 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-top: 32rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-text);
}

.subtitle {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
  display: block;
}

.credit-badge {
  display: flex;
  align-items: center;
  background: #f0fdf4;
  padding: 8rpx 20rpx;
  border-radius: 48rpx;
  border: 2rpx solid #dcfce7;
}

.badge-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.badge-text {
  font-size: 24rpx;
  color: var(--color-primary-dark);
  font-weight: 500;
}

/* Banner */
.banner {
  margin-top: 48rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  height: 280rpx;
  position: relative;
  background: linear-gradient(135deg, #22c55e, #059669);
}

.banner-bg {
  width: 100%;
  height: 100%;
  opacity: 0.3;
}

.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx;
}

.banner-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-white);
  display: block;
}

.banner-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 8rpx;
  display: block;
}

/* 功能入口 */
.features {
  margin-top: 48rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  background: var(--color-white);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.feature-item.disabled {
  opacity: 0.6;
}

.feature-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.feature-icon.green {
  background: #dcfce7;
}

.feature-icon.blue {
  background: #dbeafe;
}

.feature-info {
  flex: 1;
  margin-left: 24rpx;
}

.feature-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
}

.feature-desc {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 6rpx;
  display: block;
}

.feature-arrow {
  font-size: 40rpx;
  color: #d1d5db;
}

.tag-dev {
  font-size: 18rpx;
  background: #f3f4f6;
  color: #9ca3af;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* 效果展示 */
.demo-section {
  margin-top: 48rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 24rpx;
  display: block;
}

.demo-grid {
  display: flex;
  gap: 20rpx;
}

.demo-card {
  flex: 1;
  border-radius: var(--radius-sm);
  overflow: hidden;
  border: 2rpx solid var(--color-border);
  position: relative;
}

.demo-img {
  width: 100%;
  height: 220rpx;
}

.demo-label {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 18rpx;
  color: var(--color-white);
}

.demo-label.before {
  background: rgba(0, 0, 0, 0.5);
}

.demo-label.after {
  background: rgba(34, 197, 94, 0.8);
}
