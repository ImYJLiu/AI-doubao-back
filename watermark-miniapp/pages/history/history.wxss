.container {
  padding: 32rpx;
  padding-bottom: 160rpx;
}

/* 顶部 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 24rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
}

.manage-btn {
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 500;
}

/* 过滤器 */
.filters {
  display: flex;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.filter-tag {
  padding: 12rpx 28rpx;
  border-radius: 48rpx;
  background: #f3f4f6;
  color: var(--color-text-secondary);
  font-size: 24rpx;
}

.filter-tag.active {
  background: #dcfce7;
  color: var(--color-primary-dark);
}

/* 网格 */
.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.grid-item {
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--color-white);
  box-shadow: var(--shadow-card);
}

.grid-item.selected {
  border: 4rpx solid var(--color-primary);
}

.item-img {
  width: 100%;
  height: 300rpx;
  aspect-ratio: 3/4;
}

.item-info {
  padding: 16rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-date {
  font-size: 20rpx;
  color: #9ca3af;
}

.action-btn {
  font-size: 28rpx;
}

.item-checkbox {
  display: flex;
  align-items: center;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #d1d5db;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: var(--color-white);
}

.checkbox.checked {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

/* 批量操作 */
.batch-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--color-white);
  border-top: 2rpx solid var(--color-border);
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 24rpx);
  z-index: 100;
}

.select-all {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: var(--color-text);
}

.btn-delete {
  background: #ef4444;
  color: var(--color-white);
  border-radius: var(--radius-sm);
  font-size: 26rpx;
  padding: 16rpx 40rpx;
  line-height: 1.5;
}

.btn-delete[disabled] {
  background: #d1d5db;
}
