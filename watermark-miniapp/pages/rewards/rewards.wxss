.page {
  min-height: 100vh;
  background: var(--color-bg);
}

/* 顶部绿色区域 */
.header-bg {
  background: linear-gradient(180deg, #dcfce7 0%, var(--color-bg) 100%);
  padding: 120rpx 40rpx 60rpx;
  padding-top: 160rpx;
}

.header-content {
  text-align: center;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text);
  display: block;
  margin-bottom: 40rpx;
}

.credit-card {
  background: var(--color-white);
  border-radius: var(--radius-lg);
  padding: 48rpx;
  box-shadow: var(--shadow-card);
}

.credit-num {
  font-size: 80rpx;
  font-weight: 700;
  color: var(--color-primary);
  display: block;
}

.credit-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: 24rpx;
}

.credit-bar {
  height: 12rpx;
  background: #f3f4f6;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.credit-bar-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: 6rpx;
  transition: width 0.3s;
}

.credit-tip {
  font-size: 22rpx;
  color: #9ca3af;
}

/* 任务列表 */
.tasks {
  padding: 0 32rpx;
  padding-bottom: 160rpx;
}

.task-card {
  display: flex;
  align-items: center;
  background: var(--color-white);
  border-radius: var(--radius-md);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.task-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.task-icon.orange {
  background: #fff7ed;
}

.task-icon.blue {
  background: #eff6ff;
}

.task-icon.gold {
  background: #fefce8;
}

.task-info {
  flex: 1;
}

.task-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
}

.task-desc {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 6rpx;
  display: block;
}

.task-btn {
  padding: 16rpx 32rpx;
  border-radius: var(--radius-sm);
  font-size: 26rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.task-btn.green {
  background: var(--color-primary);
  color: var(--color-white);
}

.task-btn.white {
  background: var(--color-white);
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
}

/* VIP卡片 */
.vip-card {
  background: #111827;
}

.vip-card .task-title {
  color: var(--color-white);
}

.vip-card .task-desc {
  color: #9ca3af;
}

.vip-tag {
  font-size: 18rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #fbbf24;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-top: 8rpx;
  display: inline-block;
}

.task-btn.vip {
  background: transparent;
}

.vip-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #fbbf24;
}

/* 广告遮罩 */
.ad-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #000000;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.ad-content {
  text-align: center;
  color: var(--color-white);
}

.ad-tip {
  font-size: 36rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 24rpx;
}

.ad-countdown {
  font-size: 60rpx;
  font-weight: 700;
  color: var(--color-primary);
  display: block;
  margin-bottom: 24rpx;
}

.ad-hint {
  font-size: 24rpx;
  color: #9ca3af;
}
