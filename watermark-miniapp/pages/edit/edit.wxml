<view class="edit-page">
  <!-- 顶部工具栏 -->
  <view class="toolbar">
    <view class="tool-btn" bindtap="onClose">
      <text class="tool-icon">✕</text>
    </view>
    <view class="tool-group">
      <view class="tool-btn {{canUndo ? '' : 'disabled'}}" bindtap="onUndo">
        <text class="tool-icon">↩</text>
      </view>
      <view class="tool-btn {{canRedo ? '' : 'disabled'}}" bindtap="onRedo">
        <text class="tool-icon">↪</text>
      </view>
    </view>
    <view class="process-btn {{processBtnClass}}" bindtap="onConfirm">
      <text>{{processBtnText}}</text>
    </view>
  </view>

  <!-- 画布区域 -->
  <view class="canvas-area">
    <image
      class="source-image"
      src="{{imageUrl}}"
      mode="aspectFit"
      bindload="onImageLoad"
    ></image>
    
    <canvas
      type="2d"
      id="mask-canvas"
      class="mask-canvas"
      bindtouchstart="onTouchStart"
      bindtouchmove="onTouchMove"
      bindtouchend="onTouchEnd"
    ></canvas>
  </view>

  <!-- 底部控制栏 -->
  <view class="controls">
    <!-- 工具切换 -->
    <view class="tools">
      <view class="tool-item {{activeTool === 'brush' ? 'active' : ''}}" data-tool="brush" bindtap="switchTool">
        <text class="tool-emoji">🖌️</text>
        <text class="tool-name">画笔</text>
      </view>
      <view class="tool-item {{canClear ? '' : 'disabled'}}" bindtap="onClear">
        <text class="tool-emoji">🧹</text>
        <text class="tool-name">清空</text>
      </view>
      <view class="tool-item disabled">
        <text class="tool-emoji">🔍</text>
        <text class="tool-name">缩放</text>
      </view>
      <view class="tool-item disabled">
        <text class="tool-emoji">✂️</text>
        <text class="tool-name">套索</text>
      </view>
    </view>

    <!-- 笔刷大小 -->
    <view class="brush-size">
      <text class="size-label">笔刷大小</text>
      <slider
        class="size-slider"
        min="5"
        max="50"
        value="{{brushSize}}"
        activeColor="#22c55e"
        block-size="20"
        bindchange="onBrushSizeChange"
      />
      <text class="size-value">{{brushSize}}px</text>
    </view>
  </view>

  <!-- 加载遮罩 -->
  <loading-overlay show="{{processing}}" title="AI处理中" desc="正在智能消除水印，请稍候..."></loading-overlay>
</view>
