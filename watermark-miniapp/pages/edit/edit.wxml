<view class="edit-page">
  <!-- 顶部工具栏 -->
  <view class="toolbar">
    <view class="tool-btn" bindtap="onClose">
      <text class="tool-icon">✕</text>
    </view>
    <view class="tool-group">
      <view class="tool-btn {{canUndo ? '' : 'disabled'}}" bindtap="onUndo">
        <text class="tool-icon">↩</text>
      </view>
      <view class="tool-btn {{canRedo ? '' : 'disabled'}}" bindtap="onRedo">
        <text class="tool-icon">↪</text>
      </view>
    </view>
    <view class="process-btn {{processBtnClass}}" bindtap="onConfirm">
      <text>{{processBtnText}}</text>
    </view>
  </view>

  <!-- 画布区域 -->
  <view class="canvas-area">
    <!-- 原图始终存在，避免切换时黑屏（优先用本地路径，iOS不支持HTTP图片渲染） -->
    <image
      class="source-image"
      src="{{imagePath || imageUrl}}"
      mode="aspectFit"
      bindload="onImageLoad"
      binderror="onImageError"
    ></image>

    <!-- 结果图叠加（加载完成后淡入，避免黑屏） -->
    <image
      wx:if="{{previewResultUrl}}"
      class="source-image result-preview {{previewLoaded ? 'loaded' : 'loading'}}"
      src="{{previewResultUrl}}"
      mode="aspectFit"
      bindload="onPreviewImageLoad"
    ></image>

    <!-- 画布始终在最上层，预览成功后画布已清空（透明），结果图自然透出 -->
    <canvas
      type="2d"
      id="mask-canvas"
      class="mask-canvas"
      bindtouchstart="onTouchStart"
      bindtouchmove="onTouchMove"
      bindtouchend="onTouchEnd"
    ></canvas>
  </view>

  <!-- 底部控制栏 -->
  <view class="controls">
    <!-- 笔刷大小 -->
    <view class="brush-size">
      <text class="size-label">🖌️ 笔刷大小</text>
      <slider
        class="size-slider"
        min="5"
        max="50"
        value="{{brushSize}}"
        activeColor="#22c55e"
        block-size="20"
        bindchange="onBrushSizeChange"
      />
      <text class="size-value">{{brushSize}}px</text>
    </view>
  </view>

  <!-- 加载遮罩：处理中 / 预览生成中 -->
  <loading-overlay show="{{processing || isPreviewing}}" title="{{isPreviewing ? 'AI预览生成中' : 'AI处理中'}}" desc="{{isPreviewing ? '正在智能消除水印预览...' : '正在智能消除水印，请稍候...'}}"></loading-overlay>
</view>
