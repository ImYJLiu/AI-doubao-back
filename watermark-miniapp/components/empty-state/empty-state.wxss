.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}

.icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 30rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.desc {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 40rpx;
}

.btn {
  background: var(--color-primary);
  color: var(--color-white);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  padding: 16rpx 48rpx;
}
