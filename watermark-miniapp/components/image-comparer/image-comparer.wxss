.comparer {
  position: relative;
  border-radius: var(--radius-md);
  overflow: hidden;
  background: #1a1a1a;
}

.img-before,
.img-after {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.img-after-wrapper {
  position: absolute;
  top: 0;
  left: 0;
  height: 100%;
  overflow: hidden;
}

.img-after {
  width: 100vw; /* 保证始终占满整个比较区域 */
  height: 100%;
}

.slider-area {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.slider-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
  background: var(--color-white);
  border-radius: 50%;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.slider-line {
  position: absolute;
  width: 4rpx;
  height: 100%;
  background: var(--color-white);
  left: 50%;
  top: -100%;
  transform: translateX(-50%);
}

.slider-handle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.arrow {
  font-size: 20rpx;
  color: var(--color-text);
}

.arrow.left {
  margin-right: 4rpx;
}

.arrow.right {
  margin-left: 4rpx;
}

.label {
  position: absolute;
  bottom: 16rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  color: var(--color-white);
  z-index: 10;
}

.label-before {
  left: 16rpx;
  background: rgba(0, 0, 0, 0.5);
}

.label-after {
  right: 16rpx;
  background: rgba(34, 197, 94, 0.8);
}
